# === Binance API (Phase8 模擬交易 / Phase9 實盤) ===
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# === LINE Messaging API (Phase8 每日報告 + 心跳異常通知) ===
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=your_line_user_id_here

# === Web Dashboard ===
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password
SECRET_KEY=generate_a_random_secret_key_here

# === System ===
LOG_LEVEL=INFO
# paper=僅 log 不下單 | live=實盤下單（須 BINANCE_TESTNET=false 且 API Key 為正式站）
TRADING_MODE=paper
TRADING_INITIAL_BALANCE=300
