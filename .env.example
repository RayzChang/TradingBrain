# === Binance API (Demo / 實盤) ===
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# true=Demo(testnet.binancefuture.com) / false=正式站
BINANCE_TESTNET=true
# Testnet 時是否放寬否決（恐懼貪婪/資金費率不擋），方便驗證下單
RELAX_VETO_ON_TESTNET=true

# === LINE Messaging API (推播通知) ===
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=your_line_user_id_here

# === Web Dashboard ===
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password
SECRET_KEY=generate_a_random_secret_key_here

# === System ===
LOG_LEVEL=INFO
# paper=僅 log 不下單 | live=透過 API 實際下單
TRADING_MODE=live
TRADING_INITIAL_BALANCE=5000

# === 全倉/逐倉與槓桿（跑前執行 python setup_testnet.py 會套用到交易所）===
# 全倉=CROSSED，逐倉=ISOLATED
MARGIN_TYPE=CROSSED
DEFAULT_LEVERAGE=5
